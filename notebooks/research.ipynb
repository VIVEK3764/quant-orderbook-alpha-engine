   "source": [
    "# Real-Time Order Book Alpha Research Dashboard\n",
    "---\n",
    "This notebook demonstrates the loading and visualization of engineered alpha features and model performance."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "\n",
    "plt.style.use('dark_background')\n",
    "sns.set_theme(style=\"darkgrid\", palette=\"pastel\")\n",
    "\n",
    "# Update path if running outside the project root\n",
    "import sys\n",
    "sys.path.append('..')\n",
    "from src.config import STORAGE"
   ],
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Load Processed Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "features_path = os.path.join(STORAGE.PROCESSED_DIR, \"features.parquet\")\n",
    "if os.path.exists(features_path):\n",
    "    df_features = pd.read_parquet(features_path)\n",
    "    display(df_features.head())\n",
    "    \n",
    "    plt.figure(figsize=(14, 4))\n",
    "    plt.plot(pd.to_datetime(df_features['timestamp'], unit='ms'), df_features['mid_price'])\n",
    "    plt.title('Mid Price Over Time')\n",
    "    plt.show()\n",
    "else:\n",
    "    print(\"Features not found. Run the ingestion and feature engineering pipelines first.\")"
   ],
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Feature Correlations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "if 'df_features' in locals():\n",
    "    corr = df_features[['spread', 'depth_imbalance', 'volatility_10', 'volatility_50', 'ofi', 'returns']].corr()\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    sns.heatmap(corr, annot=True, cmap=\"coolwarm\", fmt=\".2f\")\n",
    "    plt.title(\"Feature Correlation Matrix\")\n",
    "    plt.show()"
   ],
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Analyze Alpha Model Predictions & Backtest Performance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "pred_path = os.path.join(STORAGE.PROCESSED_DIR, \"predictions.parquet\")\n",
    "if os.path.exists(pred_path):\n",
    "    df_preds = pd.read_parquet(pred_path)\n",
    "    \n",
    "    # Scatter Plot of Actual Return vs Predicted Return\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    plt.scatter(df_preds['predicted_return'], df_preds['actual_return'], alpha=0.5)\n",
    "    plt.xlabel('Predicted Return')\n",
    "    plt.ylabel('Actual Return')\n",
    "    plt.title('Prediction vs Actual')\n",
    "    # Add a reference line\n",
    "    min_val = min(df_preds['predicted_return'].min(), df_preds['actual_return'].min())\n",
    "    max_val = max(df_preds['predicted_return'].max(), df_preds['actual_return'].max())\n",
    "    plt.plot([min_val, max_val], [min_val, max_val], 'r--')\n",
    "    plt.show()\n",
    "else:\n",
    "    print(\"Predictions not found. Run the alpha_model pipeline first.\")"
   ],
   "outputs": []
  }
 ],
